---
import { SUPPORTED_LANGS, localizePath } from "@/i18n";
import type { Lang, NavKey, Translation } from "@/i18n/types";

interface Props {
  lang: Lang;
  t: Translation;
  activeNav?: NavKey;
  path?: string;
  isLanding?: boolean;
}

const { lang, t, activeNav = "home", path = "", isLanding = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const iconButtonClass = "inline-flex h-10 w-10 items-center justify-center rounded-xl border";

const otherLangs = SUPPORTED_LANGS.filter((item) => item !== lang);

const navItems: Array<{ key: NavKey; href: string; spy: boolean }> = [
  {
    key: "home",
    href: isLanding ? "#home" : localizePath(lang),
    spy: true
  },
  {
    key: "about",
    href: isLanding ? "#about" : `${localizePath(lang)}#about`,
    spy: true
  },
  {
    key: "projects",
    href: isLanding ? "#projects" : `${localizePath(lang)}#projects`,
    spy: true
  },
  {
    key: "blog",
    href: localizePath(lang, "blog/"),
    spy: false
  },
  {
    key: "contact",
    href: isLanding ? "#contact" : `${localizePath(lang)}#contact`,
    spy: true
  }
];

const themeText = lang === "pt" ? "Alternar tema" : "Toggle theme";
---

<header
  class="sticky top-0 z-30 border-b backdrop-blur-md"
  style="border-color:var(--border);background-color:var(--bg);"
  data-landing={isLanding ? "true" : "false"}
>
  <div class="mx-auto flex w-full max-w-content items-center justify-between px-5 py-4 md:px-8">
    <a
      href={localizePath(lang)}
      class:list={[iconButtonClass, "overflow-hidden hover:opacity-80"]}
      style="border-color:var(--border);"
      aria-label="Lucas Esteves"
      title="Lucas Esteves"
    >
      <img
        src={`${baseUrl}brand/lucas-mark-light.svg`}
        alt="Lucas Esteves logo"
        class="h-full w-full object-cover dark:hidden"
      />
      <img
        src={`${baseUrl}brand/lucas-mark.svg`}
        alt="Lucas Esteves logo"
        class="hidden h-full w-full object-cover dark:block"
      />
    </a>

    <nav class="hidden items-center gap-5 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            data-nav-key={item.key}
            data-spy-link={item.spy ? "true" : "false"}
            class:list={["text-sm font-medium hover:opacity-80", activeNav === item.key && "font-semibold"]}
            style={activeNav === item.key ? "color:var(--text);" : "color:var(--muted);"}
          >
            {t.nav[item.key]}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        type="button"
        class:list={[iconButtonClass, "btn-ghost"]}
        aria-label={themeText}
        title={themeText}
      >
        <svg
          id="theme-icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 1 0 9.8 9.8Z"></path>
        </svg>
        <svg
          id="theme-icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="hidden h-5 w-5"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
      </button>
      {
        otherLangs.map((item) => {
          const itemCode = item.toLowerCase();
          return (
            <a
              href={localizePath(item as Lang, path)}
              class:list={[iconButtonClass, "btn-ghost text-xs font-semibold uppercase"]}
            >
              {itemCode}
            </a>
          );
        })
      }
    </div>
  </div>

  <nav class="mx-auto flex w-full max-w-content gap-2 overflow-x-auto px-5 pb-4 md:hidden">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          data-nav-key={item.key}
          data-spy-link={item.spy ? "true" : "false"}
          class:list={[
            "whitespace-nowrap rounded-lg border px-3 py-1.5 text-xs font-medium",
            activeNav === item.key && "font-semibold"
          ]}
          style={
            activeNav === item.key
              ? "border-color:var(--text);color:var(--text);"
              : "border-color:var(--border);color:var(--muted);"
          }
        >
          {t.nav[item.key]}
        </a>
      ))
    }
  </nav>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const button = document.querySelector("#theme-toggle");
    const moonIcon = document.querySelector("#theme-icon-moon");
    const sunIcon = document.querySelector("#theme-icon-sun");

    if (
      !(button instanceof HTMLButtonElement) ||
      !(moonIcon instanceof SVGElement) ||
      !(sunIcon instanceof SVGElement)
    ) {
      return;
    }

    const syncThemeButton = () => {
      const isDark = root.classList.contains("dark");
      button.setAttribute("aria-pressed", isDark ? "true" : "false");
      moonIcon.classList.toggle("hidden", !isDark);
      sunIcon.classList.toggle("hidden", isDark);
    };

    syncThemeButton();

    button.addEventListener("click", () => {
      const nextTheme = root.classList.contains("dark") ? "light" : "dark";
      root.classList.toggle("dark", nextTheme === "dark");
      localStorage.setItem("theme", nextTheme);
      syncThemeButton();
      if (typeof window.__setSiteFavicon === "function") {
        window.__setSiteFavicon(nextTheme);
      }
      window.dispatchEvent(new CustomEvent("themechange", { detail: { theme: nextTheme } }));
    });

    const header = document.querySelector("header[data-landing='true']");
    if (!(header instanceof HTMLElement)) {
      return;
    }

    const sectionKeys = ["home", "about", "projects", "contact"];
    const sections = sectionKeys
      .map((key) => ({ key, element: document.getElementById(key) }))
      .filter((item) => item.element instanceof HTMLElement);

    const links = Array.from(document.querySelectorAll("a[data-spy-link='true']"));
    if (sections.length === 0 || links.length === 0) {
      return;
    }

    const setActive = (key) => {
      links.forEach((link) => {
        const navKey = link.getAttribute("data-nav-key");
        const isActive = navKey === key;
        link.classList.toggle("font-semibold", isActive);
        if (link.classList.contains("border")) {
          link.style.borderColor = isActive ? "var(--text)" : "var(--border)";
        }
        link.style.color = isActive ? "var(--text)" : "var(--muted)";
      });
    };

    setActive("home");

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (visible.length === 0) {
          return;
        }

        const id = visible[0].target.id;
        if (sectionKeys.includes(id)) {
          setActive(id);
        }
      },
      {
        threshold: [0.35, 0.6, 0.9],
        rootMargin: "-20% 0px -40% 0px"
      }
    );

    sections.forEach((section) => {
      observer.observe(section.element);
    });
  })();
</script>
