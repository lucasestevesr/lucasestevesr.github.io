---
import type { Project } from "@/data/projects";
import type { Translation } from "@/i18n/types";

interface Props {
  project: Project;
  t: Translation;
}

const { project, t } = Astro.props;
---

<article class="surface flex h-full flex-col p-6 transition-colors duration-200 hover:bg-[var(--surface-soft)]">
  <h3 class="text-xl font-semibold" style="color:var(--text);">{project.title}</h3>
  <p class="mt-3 text-sm leading-7 text-muted">{project.description}</p>

  <div class="mt-4 flex flex-wrap gap-2">
    {
      project.stack.map((item) => (
        <span class="chip">
          {item}
        </span>
      ))
    }
  </div>

  <div class="mt-6 flex w-full flex-wrap items-center justify-center gap-4 text-sm">
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center justify-center leading-none hover:opacity-70"
      aria-label={t.projects.github}
      title={t.projects.github}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-8 w-8" aria-hidden="true">
        <path
          fill-rule="evenodd"
          d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.21.68-.48v-1.7c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.61.07-.61 1 .07 1.52 1.01 1.52 1.01.88 1.49 2.31 1.06 2.87.81.09-.64.35-1.06.63-1.3-2.22-.25-4.55-1.09-4.55-4.87 0-1.08.4-1.96 1.03-2.65-.11-.25-.45-1.27.1-2.64 0 0 .84-.26 2.75 1.01a9.66 9.66 0 0 1 5 0c1.91-1.27 2.75-1.01 2.75-1.01.55 1.37.21 2.39.1 2.64.64.69 1.03 1.57 1.03 2.65 0 3.79-2.33 4.62-4.56 4.86.36.3.68.9.68 1.82v2.7c0 .27.18.57.69.47A10 10 0 0 0 12 2Z"
          clip-rule="evenodd"
        />
      </svg>
    </a>
    {
      project.demoUrl && (
        <a
          href={project.demoUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center leading-none hover:opacity-70"
          aria-label={t.projects.demo}
          title={t.projects.demo}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            class="h-8 w-8"
            aria-hidden="true"
          >
            <path d="M14 3h7v7"></path>
            <path d="M10 14 21 3"></path>
            <path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path>
          </svg>
        </a>
      )
    }
  </div>
</article>
