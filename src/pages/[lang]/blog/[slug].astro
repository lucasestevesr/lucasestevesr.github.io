---
import { getCollection } from "astro:content";
import { getTranslation, isValidLang, localizePath } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/utils/date";
import { getReadingTime } from "@/utils/readingTime";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => {
    const [, ...slugParts] = post.slug.split("/");
    return {
      params: {
        lang: post.data.lang,
        slug: slugParts.join("/")
      },
      props: {
        post
      }
    };
  });
}

const { lang, slug } = Astro.params;

if (!lang || !isValidLang(lang)) {
  throw new Error(`Invalid language route: ${lang}`);
}

const { post } = Astro.props;

if (!post || !slug) {
  throw new Error("Post not found.");
}

const t = getTranslation(lang);
const { Content } = await post.render();
const readingTime = getReadingTime(post.body);
---

<BaseLayout
  lang={lang}
  activeNav="blog"
  title={post.data.title}
  description={post.data.description}
  path="blog/"
>
  <article class="mx-auto mt-10 max-w-4xl md:mt-14">
    <a href={localizePath(lang, "blog/")} class="text-sm font-semibold hover:opacity-70" style="color:var(--text);">
      ← {t.blog.backToBlog}
    </a>

    <header class="surface mt-6 p-6 md:p-8">
      <p class="text-muted text-xs uppercase tracking-[0.18em]">
        {formatDate(post.data.date, t.locale)} · {t.blog.readingTime}: {readingTime} {t.blog.minutes}
      </p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl" style="color:var(--text);">{post.data.title}</h1>
      <p class="text-muted mt-4 text-base leading-8">{post.data.description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {
          post.data.tags.map((tag: string) => (
            <span class="chip">
              #{tag}
            </span>
          ))
        }
      </div>
    </header>

    <div class="surface prose-custom mt-8 p-6 md:p-10">
      <Content />
    </div>
  </article>
</BaseLayout>
