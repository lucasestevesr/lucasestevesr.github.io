---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { getTranslation } from "@/i18n";
import type { Lang, NavKey } from "@/i18n/types";
import "@/styles/global.css";

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  activeNav?: NavKey;
  path?: string;
  isLanding?: boolean;
}

const { lang, title, description, activeNav = "home", path = "", isLanding = false } = Astro.props;
const t = getTranslation(lang);
const brandTitle = "hi, i'm lucas";
const seoTitle =
  title && title !== t.seo.siteTitle ? `${title} | ${brandTitle}` : brandTitle;
const seoDescription = description ?? t.seo.siteDescription;
const darkFaviconHref = `${import.meta.env.BASE_URL}favicon.svg`;
const lightFaviconHref = `${import.meta.env.BASE_URL}favicon-light.svg`;
---

<!doctype html>
<html lang={t.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link id="site-favicon" rel="icon" type="image/svg+xml" href={darkFaviconHref} />
    <link id="site-favicon-shortcut" rel="shortcut icon" href={darkFaviconHref} />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta name="theme-color" content="#0b0b0b" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={t.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const shouldUseDark = stored ? stored === "dark" : systemPrefersDark;
        document.documentElement.classList.toggle("dark", shouldUseDark);
      })();
    </script>
    <script is:inline>
      (() => {
        const darkHref = {JSON.stringify(darkFaviconHref)};
        const lightHref = {JSON.stringify(lightFaviconHref)};
        const head = document.head;

        const applyFavicon = (forcedTheme) => {
          const isDark = forcedTheme
            ? forcedTheme === "dark"
            : document.documentElement.classList.contains("dark");
          const hrefBase = isDark ? darkHref : lightHref;
          const href = `${hrefBase}?v=${Date.now()}`;

          document.getElementById("site-favicon")?.remove();
          document.getElementById("site-favicon-shortcut")?.remove();

          const favicon = document.createElement("link");
          favicon.id = "site-favicon";
          favicon.rel = "icon";
          favicon.type = "image/svg+xml";
          favicon.href = href;

          const shortcut = document.createElement("link");
          shortcut.id = "site-favicon-shortcut";
          shortcut.rel = "shortcut icon";
          shortcut.href = href;

          head.appendChild(favicon);
          head.appendChild(shortcut);
        };

        applyFavicon();
        window.__setSiteFavicon = applyFavicon;

        const observer = new MutationObserver(() => {
          applyFavicon();
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"]
        });

        window.addEventListener("themechange", (event) => {
          const theme = event?.detail?.theme;
          applyFavicon(theme);
        });
      })();
    </script>
  </head>
  <body class="font-sans">
    <Header lang={lang} t={t} activeNav={activeNav} path={path} isLanding={isLanding} />

    <main class="mx-auto w-full max-w-content px-5 pb-16 pt-2 md:px-8 md:pt-4">
      <slot />
    </main>

    <Footer lang={lang} t={t} />
  </body>
</html>
